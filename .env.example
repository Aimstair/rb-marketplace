# Core
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/marketplace_local
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-base64
AUTH_SECRET=replace-with-random-base64
AUTH_TRUST_HOST=true

# Realtime (Pusher)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap1
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap1
ENABLE_REALTIME_MESSAGING_FEATURE=true
NEXT_PUBLIC_ENABLE_REALTIME_MESSAGING_FEATURE=true

# File Uploads
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# Email
RESEND_API_KEY=
EMAIL_FROM=RbMarket <no-reply@rbmarket.app>

# Payments
ACTIVE_PAYMENT_PROVIDER=paypal
ACTIVE_SUBSCRIPTION_PAYMENT_PROVIDER=paypal
ENABLED_PAYMENT_PROVIDERS=paypal
ENABLED_SUBSCRIPTION_PAYMENT_PROVIDERS=paypal

PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
ENABLE_PAYMONGO_WEBHOOK=false

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE_URL=https://api-m.paypal.com
PAYPAL_SUBSCRIPTION_PENDING_TTL_MINUTES=60

# Pending payment cleanup
PAYMENT_CLEANUP_CRON_SECRET=
DELETE_EXPIRED_PAYPAL_PENDING_SUBSCRIPTIONS=false

# Feature Flags and Cron Secrets
ENABLE_GIVEAWAY_FEATURE=true
GIVEAWAY_CRON_SECRET=
ENABLE_EMAIL_NOTIFICATIONS_FEATURE=true
EMAIL_DIGEST_CRON_SECRET=
EMAIL_INACTIVITY_CRON_SECRET=

# Optional: distributed rate limit store
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
